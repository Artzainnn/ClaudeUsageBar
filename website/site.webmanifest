{
  "name": "ClaudeUsageBar",
  "short_name": "ClaudeUsageBar",
  "description": "Track your Claude usage and live Claude service status from your Mac menu bar.",
  "start_url": "/",
  "display": "standalone",
  "background_color": "#0d0d0f",
